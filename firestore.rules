
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permettre la lecture publique pour toutes les données informatives (Menu, Galerie, Équipe, Jobs)
    // L'écriture est également permise pour faciliter la gestion du prototype
    
    match /dishes/{id} { 
      allow read, write: if true; 
    }
    
    match /gallery/{id} { 
      allow read, write: if true; 
    }
    
    match /employees/{id} { 
      allow read, write: if true; 
    }
    
    match /jobs/{id} { 
      allow read, list, get, write: if true; 
    }
    
    // Permettre la lecture/écriture pour les profils clients
    match /customers/{id} { 
      allow read, write: if true; 
    }
    
    // Permettre la lecture/écriture pour les commandes
    match /orders/{id} {
      allow read, write: if true;
      match /{allSubcollections=**} { 
        allow read, write: if true; 
      }
    }
    
    // Règle de repli globale pour assurer le fonctionnement du prototype dans tous les cas
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
